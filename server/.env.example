# Database (Docker Postgres from repo docker-compose.yml)
DATABASE_URL="postgresql://dealership:dealership@localhost:5434/dealership?schema=public"
TEST_DATABASE_URL="postgresql://dealership:dealership@localhost:5434/dealership_test?schema=public"

# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# JWT
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Seed admin
SEED_ADMIN_EMAIL=admin@dealership.test
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=Dealer Admin
